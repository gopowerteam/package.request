{
  "name": "@gopowerteam/request-generate",
  "type": "commonjs",
  "version": "0.3.0",
  "private": false,
  "keywords": [
    "gopowerteam",
    "request-generate"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin/index.d.mts",
      "import": "./dist/vite-plugin/index.mjs",
      "require": "./dist/vite-plugin/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "request-download": "bin/download.mts",
    "request-generate": "bin/generate.mts"
  },
  "files": [
    "README.md",
    "bin",
    "dist",
    "vite-plugin.d.ts"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "lint": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "handlebars": "^4.7.8",
    "ora": "^9.3.0",
    "qs": "^6.15.0",
    "rxjs": "^7.8.2",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@gopowerteam/request": "workspace:*",
    "@types/node": "24",
    "@types/qs": "^6.14.0",
    "openapi-types": "^12.1.3",
    "tsdown": "0.21.0-beta.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.0.0"
  }
}
