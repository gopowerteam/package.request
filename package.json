{
  "name": "request",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "turbo run build --filter @gopowerteam/*",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "play:test": "pnpm dev --filter playground-test",
    "play:test-vite": "pnpm dev --filter playground-test-vite",
    "clear": "rimraf 'packages/*/{node_modules}' && rimraf node_modules",
    "changeset": "changeset",
    "clean": "rimraf node_modules **/*/node_modules",
    "cs:update": "changeset",
    "cs:version": "changeset version",
    "cs:tag": "changeset tag",
    "prerelease": "pnpm build",
    "release": "changeset publish",
    "prepare": "husky",
    "commit": "git-cz",
    "preinstall": "npx only-allow pnpm",
    "cs": "changeset && changeset version",
    "publish-packages": "turbo run build && changeset version && changeset publish"
  },
  "workspaces": [
    "playground/*",
    "packages/*"
  ],
  "devDependencies": {
    "@antfu/eslint-config": "7.6.1",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.4.2",
    "@types/node": "24",
    "@vitest/coverage-v8": "^3.0.0",
    "commitizen": "^4.3.1",
    "cz-customizable": "7.5.1",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "turbo": "2.8.11",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    }
  },
  "publishConfig": {
    "registry": "http://registry.npmjs.org"
  }
}
